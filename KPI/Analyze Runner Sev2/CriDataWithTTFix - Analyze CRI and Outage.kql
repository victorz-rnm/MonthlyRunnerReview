VJki6b3qxKiyaU6NzN%2Fm9Ai%2FvJgVHa7rglGKJR0smRDZXgpVN0TI9tIja41O6vn%2FBdMWwCuFJQAA
// =========================
// Parameters / Constants
// =========================
let lookbackWindow = ago(180d);
// Team scope (same IDs as your original query)
let owningTeamIds = dynamic([
  '10549','10661','67334','82812','42690','75939','68685','105484','10475','93543','82813','60163','114480','135033','151109','140105']);
let lookingRelationshipTypes = dynamic(['RESPONSIBLE','DUPLICATE']);
// =========================
// Helper functions
// =========================
// Converts (some) double-encoded HTML entities to readable text, removes tags/comments,
// and normalizes whitespace.
let CleanHtmlToText = (html:string)
{
    //
    // 1. Decode double-encoded HTML entities
    //
    let step1 = replace_string(html, "&amp;nbsp;", " ");
    let step2 = replace_string(step1, "&amp;amp;", "&");
    let step3 = replace_string(step2, "&amp;quot;", "\"");
    let step4 = replace_string(step3, "&amp;#39;", "'");
    let step5 = replace_string(step4, "&amp;lt;", "<");
    let step6 = replace_string(step5, "&amp;gt;", ">");
    //
    // 2. Decode single-encoded HTML entities
    //
    let step7 = replace_string(step6, "&nbsp;", " ");
    let step8 = replace_string(step7, "&quot;", "\"");
    let step9 = replace_string(step8, "&apos;", "'");
    let step10 = replace_string(step9, "&lt;", "<");
    let step11 = replace_string(step10, "&gt;", ">");
    //
    // 3. Remove HTML comments and tags
    //
    let step12 = replace_regex(step11, "<!--.*?-->", "");
    let step13 = replace_regex(step12, "<[^>]+>", "");
    //
    // 4. Normalize whitespace
    //
    let step14 = replace_regex(step13, "\\s+", " ");
    trim(" ", step14)
};
// Builds IcM links (same endpoints as your original helpers)
let BuildIncidentLink = (incidentId:string)
{
    strcat("https://portal.microsofticm.com/imp/v3/incidents/details/", incidentId, "/home")
};
let BuildRepairItemLink = (workItemId:string)
{
    strcat("https://dev.azure.com/msazure/One/_workitems/edit/", workItemId)
};
// Extracts the short team name after the tenant prefix "TENANT\\Team"
let GetSimpleTeamName = (fullName:string)
{
    let parts = split(fullName, "\\");
    iif(array_length(parts) > 1, tostring(parts[1]), fullName)
};
// =========================
// 1) Base incidents set (materialized)
//    - Filter early
//    - Project early (only columns needed later)
// =========================
let baseIncidents = materialize(
    cluster('icmcluster').database('IcMDataWarehouse').IncidentsSnapshotV2
    | where ModifiedDate > lookbackWindow
    | where OwningTeamId in (owningTeamIds)
    | where IncidentType =~ 'CustomerReported' or IsOutage == 1
    | extend OwningTeamNameShort = GetSimpleTeamName(OwningTeamName)
    // Same logic as your LookingDate: ResolveDate > MitigateDate > CreateDate
    | extend EffectiveDateTime = coalesce(ResolveDate, MitigateDate, CreateDate)
    | project
        IncidentId,
        Title,
        Severity,
        Status,
        Tags,
        IncidentType,
        IsOutage,
        OwningTeamNameShort,
        OwningTenantName,
        OwningContactAlias,
        CreateDate,
        ModifiedDate,
        MitigateDate,
        ResolveDate,
        EffectiveDateTime
);
// Distinct list of IncidentIds used to limit all downstream scans
let incidentIds = materialize(baseIncidents | distinct IncidentId);
// 2) exclude the ICMs that has any active parent-child or responsible-child relationship
let incidentHasParentOrResponsibleICM =
    cluster('icmcluster').database('IcMDataWarehouse').IncidentRelationships
    | where ChildIncidentId in (incidentIds)                      // ✅ restrict early (big perf win)
    | where RelationshipType in (lookingRelationshipTypes)    
    | where RelationshipType in ('RESPONSIBLE','DUPLICATE')
    | summarize arg_max(Lens_IngestionTime, *) by RelationshipId
    | where IsTombstoned == false
    | distinct ChildIncidentId;
// =========================
// 3) Latest TTx metrics (materialized)
//    - Keep only columns actually used
//    - arg_max on selected columns (faster than arg_max(*))
// =========================
let ttxLatest = materialize(
    cluster('https://icmdataro.centralus.kusto.windows.net').database('Common').Get_Icm_Incidents_WithTTx
    | where ModifiedDate > lookbackWindow
    | where IncidentId in (incidentIds)
    | summarize arg_max(
        ModifiedDate,
        RepairCount, RepairClosedCount,
        TTD, TTN, TTEng, TTFix, TTM,
        SubscriptionCount,
        IsAutoDetected, IsOutageActual,
        PostmortemTitle, PostmortemStatus,
        HasTsg,
        IsS360Related, S360Link
      ) by IncidentId
    | project
        IncidentId,
        RepairCount, RepairClosedCount,
        TTD, TTN, TTEng, TTFix, TTM,
        SubscriptionCount,
        IsAutoDetected, IsOutageActual,
        PostmortemTitle, PostmortemStatus,
        HasTsg,
        IsS360Related, S360Link
);
// =========================
// 4) IssueCategory (materialized)
//    - Filter Name early (equivalent to your max(iif(...)) logic)
//    - Keep latest by ModifiedDate per incident
// =========================
let issueCategoryLatest = materialize(
    cluster('https://icmcluster.kusto.windows.net').database('IcMDataWarehouse').IncidentCustomFieldEntries
    | where IncidentId in (incidentIds)
    | where TeamId in (owningTeamIds)
    | where Name =~ 'IssueCategory'
    | summarize arg_max(ModifiedDate, Value) by IncidentId
    | project IncidentId, Category = tostring(Value)
);
// =========================
// 5) RootCauseId per incident (materialized)
// =========================
let incidentRootCause = materialize(
    cluster('icmcluster').database('IcMDataWarehouse').IncidentsSnapshotV2
    | where ModifiedDate > lookbackWindow
    | where IncidentId in (incidentIds)
    | project IncidentId, RootCauseId
);
let rootCauseIds = materialize(
    incidentRootCause
    | where isnotempty(RootCauseId)
    | distinct RootCauseId
);
// =========================
// 6) Root cause details (latest) (materialized)
//    - Limit to only needed RootCauseIds
// =========================
let rootCausesLatest = materialize(
    cluster('icmcluster').database('IcMDataWarehouse').RootCauses
    | where RootCauseId in (rootCauseIds)
    | summarize arg_max(ModifiedDate, Title, Description, IsCausedByChange) by RootCauseId
    | project
        RootCauseId,
        RCATitle = Title,
        RCADescription = CleanHtmlToText(Description),
        IsCausedByChange
);
// =========================
// 7) Repair items list (materialized)
// =========================
let repairItemsByIncident = materialize(
    cluster('icmcluster').database('IcMDataWarehouse').IncidentBugs
    | where ModifiedDate > lookbackWindow
    | where IncidentId in (incidentIds)
    // Your original logic effectively deduped by (IncidentId, ExternalId) before make_set
    | summarize arg_max(ModifiedDate, ExternalId) by IncidentId, ExternalId
    | summarize RepairItems = make_set(ExternalId) by IncidentId
    | project IncidentId, RepairItems = tostring(RepairItems)
);
// =========================
// 8) Final assembly
//    - Left joins preserve your original shape/meaning
//    - startofday() replaces todatetime(format_datetime(...)) for better performance
//    - coalesce(...) preserves your original "empty -> 0/false" normalization
// =========================
baseIncidents
| join kind=leftouter hint.strategy=shuffle hint.num_partitions=50 (ttxLatest) on IncidentId
| join kind=leftouter hint.strategy=shuffle hint.num_partitions=50 (issueCategoryLatest) on IncidentId
| join kind=leftouter hint.strategy=shuffle hint.num_partitions=50 (incidentRootCause) on IncidentId
| join kind=leftouter hint.strategy=shuffle hint.num_partitions=50 (rootCausesLatest) on RootCauseId
| join kind=leftouter hint.strategy=shuffle hint.num_partitions=50 (repairItemsByIncident) on IncidentId
| join kind=leftanti  hint.strategy=shuffle hint.num_partitions=50 (incidentHasParentOrResponsibleICM) on $left.IncidentId == $right.ChildIncidentId
| extend
    // Preserve your date “bucket to yyyy-MM-dd” behavior
    CreateDate = startofday(CreateDate),
    LookingDate = startofday(EffectiveDateTime),
    // Preserve your NULL -> default normalization behavior
    IsOutage = coalesce(tobool(IsOutage), false),
    IsOutageActual = coalesce(tobool(IsOutageActual), false),
    HasTsg = coalesce(toint(HasTsg), 0),
    IsS360Related = coalesce(toint(IsS360Related), 0),
    IsAutoDetected = coalesce(toint(IsAutoDetected), 0),
    TTFix = coalesce(todouble(TTFix), 0.0),
    TTEng = coalesce(todouble(TTEng), 0.0),
    TTM = coalesce(todouble(TTM), 0.0),
    // Links
    icmLink = strcat("https://portal.microsofticm.com/imp/v5/incidents/details/", tostring(IncidentId), "/summary"),
    IncidentLink = BuildIncidentLink(tostring(IncidentId)),
    // Same missing RCA logic as your original
    IsMissingRCA = iif(tolower(Status) != "resolved", 0, iif(isempty(RootCauseId), 1, 0))
| project
    IncidentId,
    Severity,
    IncidentLink,
    RepairItems,
    IsMissingRCA,
    IsOutageActual,
    RCATitle,
    RCADescription,
    IsCausedByChange,
    Title,
    LookingDate,
    CreateDate,
    ModifiedDate,
    MitigateDate,
    ResolveDate,
    IncidentType,
    OwningTeamName = OwningTeamNameShort,
    OwningTenantName,
    OwningContactAlias,
    RepairCount,
    RepairClosedCount,
    TTD,
    TTN,
    TTEng,
    TTFix,
    TTM,
    SubscriptionCount,
    IsAutoDetected,
    PostmortemTitle,
    PostmortemStatus,
    Status,
    HasTsg,
    Tags = tostring(Tags),
    IsS360Related,
    S360Link = tostring(S360Link),
    Category = tostring(Category),
    RootCauseId,
    icmLink

