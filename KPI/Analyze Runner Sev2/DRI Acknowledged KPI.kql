let getIncidentLink = (incident:string)
{
    let link = strcat("https://portal.microsofticm.com/imp/v3/incidents/details/", incident, "/home");
    link    
};
// no triage team because this query is getting notification analysis
let XinyanTeamIds = dynamic(['10549', '10661', '67334', '82812', '42690', '75939', '68685', '10475', '60163', '114480', '135033','39447','150283','110503']);
let lookbackWindow = ago(365d);
// all ICM IDs that ever been sev2, sev25 in Xinyan's team
let XinyanTeamSev2ICMIDs =  cluster('icmcluster').database('IcMDataWarehouse').Incidents
| where CreateDate > lookbackWindow
//| summarize hint.num_partitions=50 hint.strategy=shuffle arg_min(ModifiedDate, *) by IncidentId
| where OwningTeamId in (XinyanTeamIds)
// all sev2 or sev25 in Xinyan's team
| where Severity in (2, 25)
| summarize by IncidentId;
// get latest state of ICMs
let AllSev2ICMs = cluster('icmcluster').database('IcMDataWarehouse').IncidentsSnapshotV2
| where CreateDate > lookbackWindow
| where IncidentId in (XinyanTeamSev2ICMIDs);
// get all Xinyan team's ICM that has transferred
let AckBases = cluster('icmcluster').database('IcMDataWarehouse').Notifications
| where ModifiedDate > lookbackWindow
| where IncidentId in (XinyanTeamSev2ICMIDs)
| where PrimaryTargetType == 'TEAMID' and isnotempty( PrimaryTarget) and isnotempty( AcknowledgeContactAlias) and Notes in ("Incident Transferred", "Severity Upgraded")
| where PrimaryTarget in (XinyanTeamIds)
| distinct AcknowledgeDate, TeamId = tostring(PrimaryTarget), AcknowledgeContactAlias, IncidentId, AckType = Notes
| join kind=leftouter
(
    // getg team name, etc
    cluster('icmcluster').database('IcMDataWarehouse').Teams
    | where isnotempty( TeamId) and isnotempty( TeamName) and isnotempty( TenantName)
    | summarize TeamName = take_any(TeamName), TenantName = take_any(TenantName) by TeamId = tostring(TeamId)
)
on TeamId
| project IncidentId, AcknowledgeDate, AcknowledgeTeamId = TeamId, AcknowledgeTeamName = TeamName, TenantName, AcknowledgeContactAlias, AcknowledgeDateInDate = format_datetime(AcknowledgeDate, 'yyyy-MM-dd'), AckType
| order by AcknowledgeDate asc;
AllSev2ICMs
//| where IncidentId in (XinyanTeamSev2ICMIDs)
| join kind = inner
(
    AckBases
)
on IncidentId
| where AcknowledgeTeamId in (XinyanTeamIds)
| extend CreateDate = format_datetime(CreateDate, 'yyyy-MM-dd')
| extend IcmType = iif(CorrelationId startswith "SDNRunners-HitCount" or Title has_all ('Runner Name:','Region:','Instance:'), "Runner", iif(Title startswith "[SdnRunner Proactive] Failed Signature:", "NCPQuality-Proactive", iif(IncidentType =~ "CustomerReported" or IncidentType =~ 'Customer Reported', "CRI", "LiveSite")))
| where IcmType in ('Runner', 'CRI', 'LiveSite') and AckType =~ 'Incident Transferred' or IcmType in ('NCPQuality-Proactive') and AckType in ('Incident Transferred','Severity Upgraded')
| project IncidentId, CreateDate, IcmType, Severity, Status, ChildCount, OwningTeamName, OwningContactAlias, Title, AcknowledgeTeamId, AcknowledgeTeamName, AcknowledgeDateInDate, AcknowledgeDate, AcknowledgeContactAlias, IcmLink = getIncidentLink(IncidentId), AckType
| sort by CreateDate asc

