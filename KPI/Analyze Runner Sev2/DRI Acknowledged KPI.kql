// =========================
// Parameters / helpers
// =========================
let lookbackWindow = ago(365d);
let BuildIncidentLink = (incidentId:string)
{
    strcat("https://portal.microsofticm.com/imp/v3/incidents/details/", incidentId, "/home")
};
// No triage team here because this query is for notification / DRI acknowledge analysis
let xinyanTeamIds = dynamic([
    '10549', '10661', '67334', '82812', '42690', '75939', '68685',
    '10475', '60163', '114480', '135033', '39447', '150283', '110503'
]);
// =========================
// 1) All ICM IDs that were EVER Sev2 / Sev2.5 in the target teams
//    Keep using raw Incidents because the requirement is historical ("ever been Sev2/25")
// =========================
let xinyanTeamSev2IncidentIds = materialize(
    cluster('icmcluster').database('IcMDataWarehouse').Incidents
    | where CreateDate > lookbackWindow
    | where OwningTeamId in (xinyanTeamIds)
    | where Severity in (2, 25)
    | distinct IncidentId
);
// =========================
// 2) Latest state of those incidents
// =========================
let latestIncidents = materialize(
    cluster('icmcluster').database('IcMDataWarehouse').IncidentsSnapshotV2
    | where CreateDate > lookbackWindow
    | where IncidentId in (xinyanTeamSev2IncidentIds)
    | project
        IncidentId,
        CreateDate,
        Severity,
        Status,
        ChildCount,
        OwningTeamName,
        OwningContactAlias,
        Title,
        IncidentType,
        CorrelationId
);
// =========================
// 3) Team lookup for acknowledge target team
//    Snapshot lookup is usually preferable for performance on latest team state. [1](https://loop.cloud.)[1](https://loop.cloud.)
// =========================
let teamLookup = materialize(
    cluster('icmcluster').database('IcMDataWarehouse').TeamsSnapshotV2()
    | where tostring(TeamId) in (xinyanTeamIds)
    | project
        AcknowledgeTeamId = tostring(TeamId),
        AcknowledgeTeamName = TeamName,
        TenantName
);
// =========================
// 4) Notification acknowledge base
//    Keep all acknowledge events for the filtered incident set
// =========================
let acknowledgeBase = materialize(
    cluster('icmcluster').database('IcMDataWarehouse').Notifications
    | where ModifiedDate > lookbackWindow
    | where IncidentId in (xinyanTeamSev2IncidentIds)
    | where PrimaryTargetType == 'TEAMID'
    | where isnotempty(PrimaryTarget)
    | where isnotempty(AcknowledgeContactAlias)
    | where Notes in ('Incident Transferred', 'Severity Upgraded')
    | where PrimaryTarget in (xinyanTeamIds)
    | project
        IncidentId,
        AcknowledgeDate,
        AcknowledgeTeamId = tostring(PrimaryTarget),
        AcknowledgeContactAlias,
        AckType = tostring(Notes)
    | distinct IncidentId, AcknowledgeDate, AcknowledgeTeamId, AcknowledgeContactAlias, AckType
    | join kind=leftouter (teamLookup) on AcknowledgeTeamId
    | extend AcknowledgeDateInDate = format_datetime(AcknowledgeDate, 'yyyy-MM-dd')
);
// =========================
// 5) Final result
// =========================
latestIncidents
| join kind=inner (acknowledgeBase) on IncidentId
| extend
    CreateDate = format_datetime(CreateDate, 'yyyy-MM-dd'),
    IcmType = case(
        CorrelationId startswith "SDNRunners-HitCount"
            or Title has_all ('Runner Name:', 'Region:', 'Instance:'), "Runner",
        Title startswith "[SdnRunner Proactive] Failed Signature:", "NCPQuality-Proactive",
        IncidentType =~ "CustomerReported" or IncidentType =~ "Customer Reported", "CRI",
        "LiveSite"
    )
| where
    (
        IcmType in ('Runner', 'CRI', 'LiveSite')
        and AckType =~ 'Incident Transferred'
    )
    or
    (
        IcmType == 'NCPQuality-Proactive'
        and AckType in ('Incident Transferred', 'Severity Upgraded')
    )
| project
    IncidentId,
    CreateDate,
    IcmType,
    Severity,
    Status,
    ChildCount,
    OwningTeamName,
    OwningContactAlias,
    Title,
    AcknowledgeTeamId,
    AcknowledgeTeamName,
    TenantName,
    AcknowledgeDateInDate,
    AcknowledgeDate,
    AcknowledgeContactAlias,
    IcmLink = BuildIncidentLink(tostring(IncidentId)),
    AckType
| sort by CreateDate asc, AcknowledgeDate asc

