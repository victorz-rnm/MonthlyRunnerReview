// =========================
// Parameters / helper functions
// =========================
let lookBackTm = ago(365d);
let getIncidentLink = (incidentId:string)
{
    strcat("https://portal.microsofticm.com/imp/v3/incidents/details/", incidentId, "/home")
};
let getSimpleTeamName = (fullName:string)
{
    let parts = split(fullName, "\\");
    iif(array_length(parts) > 1, tostring(parts[1]), fullName)
};
// Decode double/single encoded HTML entities, strip tags/comments, normalize whitespace
let TrimHtmlContent = (html:string)
{
    let s1  = replace_string(html, "&amp;nbsp;", " ");
    let s2  = replace_string(s1,   "&amp;amp;", "&");
    let s3  = replace_string(s2,   "&amp;quot;", "\"");
    let s4  = replace_string(s3,   "&amp;#39;", "'");
    let s5  = replace_string(s4,   "&amp;lt;", "<");
    let s6  = replace_string(s5,   "&amp;gt;", ">");
    let s7  = replace_string(s6,   "&nbsp;", " ");
    let s8  = replace_string(s7,   "&quot;", "\"");
    let s9  = replace_string(s8,   "&apos;", "'");
    let s10 = replace_string(s9,   "&lt;", "<");
    let s11 = replace_string(s10,  "&gt;", ">");
    let s12 = replace_regex(s11, "<!--.*?-->", "");
    let s13 = replace_regex(s12, "<[^>]+>", "");
    let s14 = replace_regex(s13, "\\s+", " ");
    trim(" ", s14)
};
let XinyanTeamIds = dynamic([
    '10549', '10661', '67334', '82812', '42690', '75939', '68685',
    '105484', '10475', '93543', '82813', '60163', '114480', '135033'
]);
let RunnerTeamId = '39447';
let RunnerFrameworkPhases = dynamic(['RefreshClientTokenAsync','PreDeploymentActions']);
let DeploymentPhases = dynamic(['CreateRg','InitialDeployment','RGCreation','Redeployment','ValidateARMTemplate']);
let DeletingRgPhase = dynamic(['DeleteRG','DeleteRg']);
let excludedRelationshipTypes = dynamic(['RESPONSIBLE','DUPLICATE']);
// =========================
// 1) Find original Sev2 runner CP incidents in target teams
//    Use raw Incidents so we can get the earliest state per incident
// =========================
let OriginalSev2RunnerIncidentIds = materialize(
    cluster('icmcluster').database('IcMDataWarehouse').Incidents
    | where CreateDate > lookBackTm
    | where (CorrelationId startswith 'SDNRunners-HitCount' and Title has 'control path') or Title startswith "[RunnerICM Aggregation CP]"
    // get earliest known row per incident, but keep only needed columns
    | summarize arg_min(ModifiedDate, OwningTeamId, Severity) by IncidentId
    | where Severity == 2
    | where OwningTeamId in (XinyanTeamIds)
    | project IncidentId
);
// =========================
// 2) Exclude incidents that currently have active parent/responsible relationships
//    Latest state per RelationshipId, keep non-tombstoned only
// =========================
let ExcludedChildIncidentIds = materialize(
    IncidentRelationships
    | where ChildIncidentId in (OriginalSev2RunnerIncidentIds)
    | where RelationshipType in (excludedRelationshipTypes)
    | summarize arg_max(Lens_IngestionTime, *) by RelationshipId
    | where IsTombstoned == false
    | distinct ChildIncidentId
);
// =========================
// 3) Base latest-state incidents after exclusion
// =========================
let BaseIncidents = materialize(
    cluster('icmcluster').database('IcMDataWarehouse').IncidentsSnapshotV2
    | where CreateDate > lookBackTm
    | where IncidentId in (OriginalSev2RunnerIncidentIds)
    | join kind=leftanti (ExcludedChildIncidentIds) on $left.IncidentId == $right.ChildIncidentId
    // ===========================================
    // Parse runner metadata from different title formats
    // ===========================================
    // 1) Normal runner title
    // Example:
    // [Control Path: RNC] Runner Name: AzNetToolsRunners.LongRunnerNicTestSuite Region: uscentraleuap Instance: azfRNCRNMLongRunnerNicTestSuiteuscentraleuapPaireuropewestProd Phase: IPV6_ILB_VM_DataPathTestViaILB Expected to Work - Vm1ToVm2
    | extend
        NormalRunnerName     = extract(@"Runner Name:\s*(.*?)\s+Region:\s*", 1, Title),
        NormalRegion         = extract(@"Region:\s*(.*?)\s+Instance:\s*", 1, Title),
        NormalRunnerInstance = extract(@"Instance:\s*(.*?)\s+Phase:\s*", 1, Title),
        NormalPhase          = extract(@"Phase:\s*(.*)$", 1, Title)
    // 2) Aggregate format with region / runnerName / runnerInstance
    // Example:
    // [Aggregate][azf-SiriusDSRLBILBSTenant-DP][uswestcentral / AzNetToolsRunners.DSRLBILBSTenant / azfSiriusDSRLBILBSTenantuswestcentralProd] 100% children Unhealthy
    | extend
        Agg3Region         = extract(@"\[Aggregate\]\[[^\]]+\]\[\s*([^/\]]+?)\s*/\s*([^/\]]+?)\s*/\s*([^\]]+?)\s*\]", 1, Title),
        Agg3RunnerName     = extract(@"\[Aggregate\]\[[^\]]+\]\[\s*([^/\]]+?)\s*/\s*([^/\]]+?)\s*/\s*([^\]]+?)\s*\]", 2, Title),
        Agg3RunnerInstance = extract(@"\[Aggregate\]\[[^\]]+\]\[\s*([^/\]]+?)\s*/\s*([^/\]]+?)\s*/\s*([^\]]+?)\s*\]", 3, Title)
    // 3) Aggregate format with only runnerGroup / region
    // Example:
    // [Aggregate][SiriusRunners-DP-Sev2][AzNetToolsRunners / germanywc] 2 of 90 children Unhealthy
    // [VNC out of capacity][Aggregate][SiriusRunners-DP-Sev2][AzNetToolsRunners / germanywc] 2 of 67 children Unhealthy
    | extend
        Agg2RunnerGroup = extract(@"\[Aggregate\]\[[^\]]+\]\[\s*([^/\]]+?)\s*/\s*([^\]]+?)\s*\]", 1, Title),
        Agg2Region      = extract(@"\[Aggregate\]\[[^\]]+\]\[\s*([^/\]]+?)\s*/\s*([^\]]+?)\s*\]", 2, Title)
    // 4) RunnerICM Aggregation CP format
    // Example:
    // [RunnerICM Aggregation CP] [Region: uswestcentral] [...]
    | extend
        CpRegion = extract(@"\[RunnerICM Aggregation CP\]\s*\[Region:\s*([^\]]+?)\]", 1, Title)
    // Final unified columns
    | extend
        RunnerName = coalesce(
            NormalRunnerName,
            Agg3RunnerName,
            iif(Title startswith "[RunnerICM Aggregation CP]", "RunnerICM Aggregation CP", "")
        ),
        RunnerInstance = coalesce(
            NormalRunnerInstance,
            Agg3RunnerInstance,
            ""
        ),
        Region = coalesce(
            NormalRegion,
            Agg3Region,
            Agg2Region,
            CpRegion,
            ""
        ),
        Phase = iif(isnotempty(NormalPhase), NormalPhase, "AggregatedPhase")
    // Fallback only after all pattern extraction attempts
    | extend
        RunnerName = iif(isnotempty(RunnerName), RunnerName, "Unknown"),
        FailureType = case(
            Phase in (RunnerFrameworkPhases), "Runner Phase",
            Phase in (DeploymentPhases), "Deployment",
            Phase in (DeletingRgPhase), "Delete RG",
            Phase contains "AggregatedPhase", "AggregatedPhase",
            "Testing Failure"
        )
    | project
        IncidentId,
        CreateDate,
        ModifiedDate,
        MitigateDate,
        ResolveDate,
        LookingDate = coalesce(ResolveDate, MitigateDate, CreateDate),
        MonitorId,
        RoutingId,
        OwningTenantId,
        OwningTenantName,
        OwningTeamId,
        OwningTeamName,
        OwningContactAlias,
        Severity,
        Status,
        Title,
        RootCauseId,
        ResponsibleTeamName,
        ResponsibleTeamId,
        Tags,
        RunnerName,
        RunnerInstance,
        Region,
        Phase,
        FailureType,
        HowFixed,
        Mitigation,
        CorrelationId
);
// Narrow all later joins to only these IDs
let ICMIDs = materialize(BaseIncidents | distinct IncidentId);
// =========================
// 4) Repair items
// =========================
let RepairItemsByIncident = materialize(
    cluster('icmcluster').database('IcMDataWarehouse').IncidentBugs
    | where CreatedDate > lookBackTm
    | where IncidentId in (ICMIDs)
    | summarize arg_max(ModifiedDate, ExternalId) by IncidentId, ExternalId
    | summarize RepairItems = make_set(ExternalId) by IncidentId
);
// =========================
// 5) Auto-correlation marker
// =========================
let AutoCorrelationByIncident = materialize(
    cluster('icmcluster').database('IcMDataWarehouse').IncidentDescriptions
    | where Date > lookBackTm
    | where IncidentId in (ICMIDs)
    | where ChangedBy == 'IcmAutoCorrelation'
    | summarize IcmAutoCorrelation = max(1) by IncidentId
);
// =========================
// 6) Severity downgrade info
// =========================
let SeverityDowngradeByIncident = materialize(
    cluster('icmcluster').database('IcMDataWarehouse').IncidentHistory
    | where ChangeDate > lookBackTm
    | where IncidentId in (ICMIDs)
    | where ChangeCategories =~ '["Edit","SeverityDowngrade"]'
    | summarize arg_max(ChangeDate, ChangedBy) by IncidentId
    | extend
        SeverityDowngradeType = case(
            ChangedBy =~ 'CN=networking-autotriage.azure.com', 'Auto-Triage',
            ChangedBy =~ 'Automation' or ChangedBy =~ 'gautosvc', 'Automation',
            'DRI'
        )
    | extend SeverityDowngradeBy = iif(SeverityDowngradeType != 'DRI', SeverityDowngradeType, ChangedBy)
    | project IncidentId, SeverityDowngradeBy, SeverityDowngradeType
);
// =========================
// 7) Root cause info
// =========================
let RootCauseIds = materialize(
    BaseIncidents
    | where isnotempty(RootCauseId)
    | distinct RootCauseId
);
let RootCausesLatest = materialize(
    cluster('icmcluster').database('IcMDataWarehouse').RootCauses
    | where RootCauseId in (RootCauseIds)
    | summarize arg_max(ModifiedDate, Title, Description) by RootCauseId
    | project
        RootCauseId,
        RCATitle = Title,
        RCADesscription = TrimHtmlContent(Description)
);
// =========================
// 8) Runner flavor / subscription lookup
// =========================
let RunnerMetadata = materialize(
    cluster('aznwsdn').database('aznwmds').MetricTelemetry
    | where name == 'E2ERunnersDeployMetric'
    | where isnotempty(RunnerFlavor) and isnotempty(SubscriptionId)
    | summarize arg_max(PreciseTimeStamp, Region, SubscriptionId, RunnerFlavor) by RunnerInstanceName
    | project
        RunnerInstanceName,
        MetricRegion = Region,
        MetricSubscriptionId = SubscriptionId,
        MetricRunnerFlavor = RunnerFlavor
    | join kind=leftouter (
        cluster('nrp').database('test').GetLatestSimpleControlPathRunnerConfigure
        | project
            RunnerInstanceName,
            ConfigSubscriptionId = SubscriptionId,
            ConfigRunnerFlavor = RunnerFlavor
    ) on RunnerInstanceName
    | extend
        RunnerFlavor = coalesce(MetricRunnerFlavor, ConfigRunnerFlavor),
        SubscriptionId = coalesce(MetricSubscriptionId, ConfigSubscriptionId)
    | project RunnerInstanceName, RunnerFlavor, SubscriptionId
);
// =========================
// 9) Final assembly
// =========================
BaseIncidents
| join kind=leftouter hint.strategy=shuffle hint.num_partitions=50 (RepairItemsByIncident) on IncidentId
| join kind=leftouter hint.strategy=shuffle hint.num_partitions=50 (AutoCorrelationByIncident) on IncidentId
| join kind=leftouter hint.strategy=shuffle hint.num_partitions=50 (SeverityDowngradeByIncident) on IncidentId
| join kind=leftouter hint.strategy=shuffle hint.num_partitions=50 (RootCausesLatest) on RootCauseId
| join kind=leftouter hint.strategy=shuffle hint.num_partitions=50 (RunnerMetadata) on $left.RunnerInstance == $right.RunnerInstanceName
| extend
    rawTags = parse_json(Tags),
    RCADesscription = iif(isnotempty(RCADesscription), TrimHtmlContent(RCADesscription), ''),
    SeverityDowngradeBy = coalesce(SeverityDowngradeBy, 'N/A'),
    SeverityDowngradeType = coalesce(SeverityDowngradeType, 'N/A'),
    IcmAutoCorrelation = coalesce(IcmAutoCorrelation, 0)
    // DRI triaged the ICM with any of these conditions
| extend  IsTriaged = iif(
        isnotempty(RootCauseId)
        or array_length(rawTags) > 0
        or OwningTeamId == RunnerTeamId
        or HowFixed in ('Transient', 'External')
        or (isnotempty(RepairItems) and array_length(RepairItems) > 0)   // corrected: has WI => triaged
        or SeverityDowngradeBy != 'N/A',
        1,
        0
    ),
    // Missing RCA
    IsMissingRCA = iif(
        tolower(Status) != 'resolved',
        0,
        iif(isempty(RootCauseId) and (isempty(RepairItems) or array_length(RepairItems) == 0), 1, 0)
    ),
    InactiveInDays = iif(Status =~ 'active', datetime_diff('day', now(), ModifiedDate), 0),
    StartOfWeek = startofweek(CreateDate),
    OwningTeamName = getSimpleTeamName(OwningTeamName),
    FinalTeamGroup = case(
        OwningTeamId == RunnerTeamId, 'Runner Team',
        OwningTeamId in (XinyanTeamIds), 'Xinyan Team',
        'Other Teams'
    ),
    TestPhase = case(
        Phase =~ 'ValidateARMTemplate', 'ValidateARMTemplate',
        Phase in (DeploymentPhases), 'Deployment RG',
        Phase in (DeletingRgPhase), 'Delete RG',
        'Others'
    )
| project
    IncidentId,
    IcmLink = getIncidentLink(tostring(IncidentId)),
    IsMissingRCA,
    IsTriaged,
    StartOfWeek,
    LookingDate,
    CreateDate,
    ModifiedDate,
    MitigateDate,
    ResolveDate,
    MonitorId,
    RoutingId,
    OwningTenantId,
    OwningTenantName,
    OwningTeamId,
    OwningTeamName,
    OwningContactAlias,
    Severity,
    Status,
    InactiveInDays,
    Title,
    RootCauseId,
    RCATitle,
    RCADesscription,
    ResponsibleTeamName,
    ResponsibleTeamId,
    Tags,
    RunnerName,
    RunnerInstance,
    Region,
    Phase,
    TestPhase,
    RunnerFlavor,
    SubscriptionId,
    FailureType,
    IcmAutoCorrelation,
    HowFixed,
    Mitigation = TrimHtmlContent(Mitigation),
    tostring(RepairItems),
    SeverityDowngradeBy,
    SeverityDowngradeType,
    FinalTeamGroup
| sort by CreateDate asc